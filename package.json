{
  "name": "vue-snap",
  "version": "1.3.0",
  "type": "module",
  "description": "Lightweight Carousel based on CSS Scroll Snap",
  "main": "dist/vue-snap.umd.js",
  "module": "dist/vue-snap.es.js",
  "unpkg": "dist/vue-snap.js",
  "types": "dist/entry.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/entry.d.ts",
      "import": "./dist/vue-snap.es.js",
      "require": "./dist/vue-snap.umd.js"
    },
    "./style.css": "./dist/vue-snap.css",
    "./dist/vue-snap.css": "./dist/vue-snap.css"
  },
  "scripts": {
    "release": "vue-tsc -b && vite build -c ./config/vite.config.ts",
    "lint": "biome check src",
    "format": "biome format --write src",
    "test": "test --passWithNoTests"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bartdominiak/vue-snap.git"
  },
  "keywords": [
    "vue",
    "vue-snap",
    "carousel",
    "slider",
    "scroll-snap"
  ],
  "author": "smugers@gmail.com",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bartdominiak/vue-snap/issues"
  },
  "homepage": "https://github.com/bartdominiak/vue-snap#README",
  "peerDependencies": {
    "vue": "^3.5.16"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "lodash": "^4.18.1",
    "sass-embedded": "^1.100.0",
    "typescript": "5",
    "vite": "^8.1.4",
    "vite-plugin-dts": "^5.0.3",
    "vue-tsc": "^3.3.7"
  }
}
